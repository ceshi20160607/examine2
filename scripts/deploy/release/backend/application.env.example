# （可选）环境变量覆盖；推荐改用 config/application.yml，见 application.yml.example

SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=9999

SPRING_DATASOURCE_URL=jdbc:mysql://127.0.0.1:3306/examine?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me

SPRING_DATA_REDIS_HOST=127.0.0.1
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=
SPRING_DATA_REDIS_DATABASE=0

EXAMINE_OPENAPI_SIGNING_MASTER_KEY=change-me-openapi-signing-key-32bytes
EXAMINE_UPLOAD_PATH=/data/examine/uploads
LOG_FILE=/var/log/examine/examine-web.log

# 可选
# EXAMINE_JAVA_XMX=512m
