# Copy this file to application.yml and edit it before starting.
# Location in release package: backend/config/application.yml
# The launcher loads this directory with spring.config.additional-location.
#
#   cp application.yml.example application.yml

spring:
  profiles:
    active: prod
  datasource:
    url: jdbc:mysql://127.0.0.1:3306/examine?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false
    username: root
    password: change-me
    driver-class-name: com.mysql.cj.jdbc.Driver
  data:
    redis:
      host: 127.0.0.1
      port: 6379
      password: ""
      database: 0
  flyway:
    enabled: true
    baseline-on-migrate: true
    baseline-version: 22
    validate-on-migrate: true
    repair-on-migrate: true

server:
  port: 9999

logging:
  file:
    name: /var/log/examine/unexamine.log
  level:
    root: INFO
    com.unique.examine: INFO

examine:
  session:
    store: redis
  flyway:
    mark-applied: "14"
  export-job:
    poll-ms: 10000
  trace:
    enabled: false
  openapi:
    # Required in production. Replace with a random 32+ character value.
    signing-master-key: replace-with-random-32-plus-chars
  upload:
    local-root-path: /data/examine/uploads
    max-size-mb: 50

springdoc:
  api-docs:
    enabled: false

knife4j:
  enable: false
