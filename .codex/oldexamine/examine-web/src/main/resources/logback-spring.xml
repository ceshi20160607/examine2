<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <property name="LOG_DIR" value="${LOG_DIR:-logs}"/>
    <property name="LOG_FILE" value="${LOG_FILE:-${LOG_DIR}/examine-web.log}"/>

    <property name="CONSOLE_PATTERN"
              value="%d{HH:mm:ss.SSS} %highlight(%-5level) %cyan(%logger{36}) - %msg%n"/>
    <property name="FILE_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{40} - %msg%n"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${CONSOLE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 滚动文件：控制体积，避免手工 RedirectStandardOutput 产生巨型单文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_FILE}</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/examine-web.%d{yyyy-MM-dd}.%i.log.gz</fileNamePattern>
            <maxFileSize>10MB</maxFileSize>
            <maxHistory>14</maxHistory>
            <totalSizeCap>100MB</totalSizeCap>
            <cleanHistoryOnStart>false</cleanHistoryOnStart>
        </rollingPolicy>
        <encoder>
            <pattern>${FILE_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 控制台：简要；详细 TRACE/SQL 只进滚动文件 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

    <logger name="TRACE.PARAM" level="INFO" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>
    <logger name="TRACE.CHAIN" level="INFO" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>
    <logger name="TRACE.RESP" level="INFO" additivity="false">
        <appender-ref ref="FILE"/>
    </logger>

    <!-- MyBatis SQL：仅写入文件（需 log-impl=Slf4jImpl） -->
    <logger name="com.unique.examine" level="INFO"/>
    <logger name="com.baomidou.mybatisplus" level="WARN"/>

    <springProfile name="dev">
        <logger name="com.unique.examine.plat.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="com.unique.examine.module.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="com.unique.examine.flow.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="com.unique.examine.app.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
        <logger name="com.unique.examine.upload.mapper" level="DEBUG" additivity="false">
            <appender-ref ref="FILE"/>
        </logger>
    </springProfile>

    <springProfile name="prod">
        <logger name="TRACE.PARAM" level="WARN"/>
        <logger name="TRACE.CHAIN" level="WARN"/>
        <logger name="TRACE.RESP" level="WARN"/>
    </springProfile>
</configuration>
