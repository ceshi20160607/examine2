<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.app.base.mapper.CredentialMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.app.base.entity.Credential">
        <id column="id" property="id" />
        <result column="client_id" property="clientId" />
        <result column="access_key" property="accessKey" />
        <result column="secret_hash" property="secretHash" />
        <result column="secret_version" property="secretVersion" />
        <result column="sign_algorithm" property="signAlgorithm" />
        <result column="status" property="status" />
        <result column="created_by" property="createdBy" />
        <result column="updated_by" property="updatedBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, client_id, access_key, secret_hash, secret_version, sign_algorithm, status, created_by, updated_by, created_at, updated_at
    </sql>

</mapper>
