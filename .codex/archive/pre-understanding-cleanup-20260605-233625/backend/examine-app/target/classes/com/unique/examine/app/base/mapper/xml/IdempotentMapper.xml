<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.app.base.mapper.IdempotentMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.app.base.entity.Idempotent">
        <id column="id" property="id" />
        <result column="client_id" property="clientId" />
        <result column="idempotent_key" property="idempotentKey" />
        <result column="request_hash" property="requestHash" />
        <result column="response_hash" property="responseHash" />
        <result column="status" property="status" />
        <result column="expired_at" property="expiredAt" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, client_id, idempotent_key, request_hash, response_hash, status, expired_at, created_at, updated_at
    </sql>

</mapper>
