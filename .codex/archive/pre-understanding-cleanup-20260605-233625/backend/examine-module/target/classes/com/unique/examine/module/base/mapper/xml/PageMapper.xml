<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.module.base.mapper.PageMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.module.base.entity.Page">
        <id column="id" property="id" />
        <result column="module_id" property="moduleId" />
        <result column="page_code" property="pageCode" />
        <result column="page_name" property="pageName" />
        <result column="page_type" property="pageType" />
        <result column="layout_json" property="layoutJson" />
        <result column="button_json" property="buttonJson" />
        <result column="status" property="status" />
        <result column="created_by" property="createdBy" />
        <result column="updated_by" property="updatedBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, module_id, page_code, page_name, page_type, layout_json, button_json, status, created_by, updated_by, created_at, updated_at, deleted
    </sql>

</mapper>
