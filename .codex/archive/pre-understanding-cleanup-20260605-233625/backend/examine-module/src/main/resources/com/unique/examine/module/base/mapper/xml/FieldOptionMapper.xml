<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.module.base.mapper.FieldOptionMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.module.base.entity.FieldOption">
        <id column="id" property="id" />
        <result column="field_id" property="fieldId" />
        <result column="option_value" property="optionValue" />
        <result column="option_label" property="optionLabel" />
        <result column="sort_order" property="sortOrder" />
        <result column="status" property="status" />
        <result column="created_by" property="createdBy" />
        <result column="updated_by" property="updatedBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
        <result column="deleted" property="deleted" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, field_id, option_value, option_label, sort_order, status, created_by, updated_by, created_at, updated_at, deleted
    </sql>

</mapper>
