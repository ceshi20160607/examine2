<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.flow.base.mapper.TaskMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.flow.base.entity.Task">
        <id column="id" property="id" />
        <result column="instance_id" property="instanceId" />
        <result column="node_key" property="nodeKey" />
        <result column="task_name" property="taskName" />
        <result column="assignee_id" property="assigneeId" />
        <result column="candidate_json" property="candidateJson" />
        <result column="status" property="status" />
        <result column="due_at" property="dueAt" />
        <result column="handled_at" property="handledAt" />
        <result column="created_by" property="createdBy" />
        <result column="updated_by" property="updatedBy" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, instance_id, node_key, task_name, assignee_id, candidate_json, status, due_at, handled_at, created_by, updated_by, created_at, updated_at
    </sql>

</mapper>
