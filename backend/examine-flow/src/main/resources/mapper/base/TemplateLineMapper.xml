<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.unique.examine.flow.base.mapper.TemplateLineMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.unique.examine.flow.base.entity.TemplateLine">
        <id column="id" property="id" />
        <result column="system_id" property="systemId" />
        <result column="template_version_id" property="templateVersionId" />
        <result column="line_key" property="lineKey" />
        <result column="from_node_key" property="fromNodeKey" />
        <result column="to_node_key" property="toNodeKey" />
        <result column="condition_mode" property="conditionMode" />
        <result column="sort_order" property="sortOrder" />
        <result column="created_at" property="createdAt" />
        <result column="updated_at" property="updatedAt" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, system_id, template_version_id, line_key, from_node_key, to_node_key, condition_mode, sort_order, created_at, updated_at
    </sql>

</mapper>
